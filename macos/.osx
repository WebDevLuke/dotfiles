# Screenshots location
defaults write com.apple.screencapture location -string "~/Downloads"

# Use the system-wide dark appearance (applies immediately)
osascript -e 'tell application "System Events" to tell appearance preferences to set dark mode to true'

# Finder: show all filename extensions
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Show scrollbars only when scrolling
defaults write NSGlobalDomain AppleShowScrollBars -string "WhenScrolling"

# Finder: show status bar
defaults write com.apple.finder ShowStatusBar -bool true

# Finder: show path bar
defaults write com.apple.finder ShowPathbar -bool true

# Set the icon size of Dock items to 70 pixels
defaults write com.apple.dock tilesize -int 65

# Dock: hide recent applications
defaults write com.apple.dock show-recents -bool false

# Dock: don't automatically rearrange Spaces based on most recent use
defaults write com.apple.dock mru-spaces -bool false

# Dock: pin a fixed set of apps (requires dockutil from the Brewfile).
# The list between the markers is regenerated by the `dockdump` command - to
# change it, arrange your Dock and run dockdump rather than editing by hand.
# dock-apps:start
dock_apps=(
	"/Applications/Google Chrome.app"
	"/Applications/Slack.app"
	"/Applications/Visual Studio Code.app"
	"/System/Applications/Notes.app"
	"/System/Applications/iPhone Mirroring.app"
	"/Applications/1Password.app"
	"/System/Applications/System Settings.app"
)
# dock-apps:end
if [ -x /opt/homebrew/bin/dockutil ]; then
	/opt/homebrew/bin/dockutil --no-restart --remove all > /dev/null 2>&1
	for dock_app in "${dock_apps[@]}"; do
		if [ -e "${dock_app}" ]; then
			/opt/homebrew/bin/dockutil --no-restart --add "${dock_app}" > /dev/null 2>&1
		else
			echo "  ⏭️  Skipping missing Dock app: ${dock_app}"
		fi
	done
fi
unset dock_apps dock_app

# Kill affected apps
for app in "Dock" "Finder" "SystemUIServer" "Terminal" "iCal"; do
	killall "${app}" > /dev/null 2>&1
done
