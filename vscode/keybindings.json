[
    {
        "key": "shift+cmd+t",
        "command": "workbench.action.tasks.showTasks"
    },
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b\r"
        },
        "when": "terminalFocus"
    }
]